{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@app/*": ["src/app/*"],
      "@data/*": ["src/data/*"],
      "@domain/*": ["src/domain/*"],
      "@usecases/*": ["src/usecases/*"],
      "@repositories/*": ["src/data/repositories/*"],
      "@redux/*": ["src/app/redux/*"]
    }
  },
  "include": ["src"]
}